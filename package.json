{
    "name": "@1adybug/eslint",
    "version": "0.0.4",
    "type": "module",
    "description": "推荐的 ESLint 配置",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rslib build",
        "dev": "rslib build --watch",
        "prepublishOnly": "npm run build",
        "format": "prettier --write .",
        "fg": "npm run format && git add . && git commit -m \"✨feature: format\"",
        "prepare": "husky"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.com/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/1adybug/eslint.git"
    },
    "homepage": "https://github.com/1adybug/eslint",
    "bugs": {
        "url": "https://github.com/1adybug/eslint/issues"
    },
    "dependencies": {
        "@eslint/js": "^9.39.3",
        "eslint-config-next": "^16.1.6",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.3.0",
        "typescript-eslint": "^8.56.1"
    },
    "devDependencies": {
        "@1adybug/prettier": "^0.0.27",
        "@eslint/config-helpers": "^0.5.2",
        "@eslint/core": "^1.1.0",
        "@rslib/core": "^0.19.6",
        "@types/node": "^24.10.13",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "eslint": "^9.39.3"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
